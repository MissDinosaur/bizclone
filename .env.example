# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# IMPORTANT: .env contains sensitive information and must NOT be committed to git

# Environment Type
ENVIRONMENT=production

# Logging
LOG_LEVEL=INFO

# Timezone for scheduling and timestamps
TIMEZONE=Europe/Berlin


# PostgreSQL Database (Required)
# This application uses PostgreSQL exclusively.
# Used by docker-compose.yml and init-db.sql

POSTGRES_USER=bizclone_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=bizclone_db

# Database Connection URL
# Docker Deployment (recommended):
DATABASE_URL=postgresql://bizclone_user:your_password@postgres_db:5432/bizclone_db

# Local Development (if running outside Docker):
# DATABASE_URL=postgresql://bizclone_user:your_password@localhost:5432/bizclone_db

# Cloud Database (e.g., AWS RDS, Azure Database):
# DATABASE_URL=postgresql://user:password@your-host.region.rds.amazonaws.com:5432/bizclone_db


# Gmail API Configuration (for email sending)
GOOGLE_CREDENTIALS_PATH=config/google/credentials.json
GOOGLE_TOKEN_PATH=config/google/token.json

# Allowed sender emails that can trigger the system, to prevent processing all the incoming emails
# CSV format: email1@example.com,email2@example.com
# You can leave it empty to allow all senders.
ALLOWED_SENDERS=your_email@example.com,another_email@example.com


# OpenAI API Configuration
OPENAI_API_KEY=sk-your-secret-key-here


# Channel Configuration
# Email Channel
CHANNEL_EMAIL_ENABLED=True
CHANNEL_EMAIL_POLL_INTERVAL=60

# Call Channel
CHANNEL_CALL_ENABLED=False
CHANNEL_CALL_POLL_INTERVAL=300

# Teams Channel
CHANNEL_TEAMS_ENABLED=False
CHANNEL_TEAMS_POLL_INTERVAL=300

# WhatsApp Channel
CHANNEL_WHATSAPP_ENABLED=False
CHANNEL_WHATSAPP_POLL_INTERVAL=300

# Facebook Channel
CHANNEL_FACEBOOK_ENABLED=False
CHANNEL_FACEBOOK_POLL_INTERVAL=300


# Application Settings
APP_TITLE=AI-Powered BizClone
HOST=0.0.0.0
PORT=8000


# Business Configuration
BUSINESS_DOMAIN=plumbing

# Company email for sending confirmations and replies
COMPANY_EMAIL=support@example.com

# Company signature for emails
COMPANY_SIGNATURE=Your Name\nPosition Title\nCompany Name\n+1 234 567 8900\nemail@example.com
