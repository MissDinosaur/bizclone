# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# IMPORTANT: .env contains sensitive information and must NOT be committed to git


# Environment Type
ENVIRONMENT=production

# Logging
LOG_LEVEL=INFO


# PostgreSQL Database (Required)
# This application uses PostgreSQL exclusively.
#
# PostgreSQL Credentials (used by docker-compose and init-db.sql)
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=your_database_name
#
# Database Connection URLs
# Local Development:
# DATABASE_URL=postgresql://your_postgres_user:your_secure_password@localhost:5432/your_database_name
#
# Docker Deployment (recommended):
DATABASE_URL=postgresql://your_postgres_user:your_secure_password@postgres:5432/your_database_name
#
# Cloud Database (e.g., AWS RDS, Azure Database):
# DATABASE_URL=postgresql://user:password@your-host.region.rds.amazonaws.com:5432/database_name


# Gmail API Configuration
GMAIL_CREDENTIALS_PATH=config/gmail/credentials.json
GMAIL_TOKEN_PATH=config/gmail/token.json
ALLOWED_SENDERS=your_email@example.com,another_email@example.com


# OpenAI API Configuration
OPENAI_API_KEY=sk-your-secret-key-here


# Channel Configuration
# Email Channel
CHANNEL_EMAIL_ENABLED=True
CHANNEL_EMAIL_POLL_INTERVAL=60

# Call Channel
CHANNEL_CALL_ENABLED=False
CHANNEL_CALL_POLL_INTERVAL=300

# Teams Channel
CHANNEL_TEAMS_ENABLED=False
CHANNEL_TEAMS_POLL_INTERVAL=300

# WhatsApp Channel
CHANNEL_WHATSAPP_ENABLED=False
CHANNEL_WHATSAPP_POLL_INTERVAL=300

# Facebook Channel
CHANNEL_FACEBOOK_ENABLED=False
CHANNEL_FACEBOOK_POLL_INTERVAL=300


# Application Settings
APP_TITLE=AI-Powered BizClone
HOST=0.0.0.0
PORT=8000


# Business Configuration
BUSINESS_DOMAIN=plumbing
COMPANY_SIGNATURE=Jacqueline LI\nOperations Manager\nHamburg Plumbing Solutions\n+49 40 12345678\ninfo@hamburgplumbing.de

# Instagram DM Configuration (Meta Graph API)
INSTAGRAM_PAGE_ACCESS_TOKEN=your-page-access-token-here
INSTAGRAM_USER_ID=your-instagram-user-id-here
CHANNEL_INSTAGRAM_ENABLED=False
CHANNEL_INSTAGRAM_POLL_INTERVAL=60
